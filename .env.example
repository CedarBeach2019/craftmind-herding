# CraftMind Herding — Configuration
# Copy this to .env and fill in your values

# Minecraft server connection
MC_HOST=localhost
MC_PORT=25565
MC_USERNAME=HerdingDog

# Bot personality (patient | aggressive | fast | methodical)
DOG_PERSONALITY=patient

# Starting skill level (apprentice | journeyman | master | elder)
DOG_LEVEL=apprentice

# Seasonal config — how many MC days per season
DAYS_PER_SEASON=7

# Alpha Dog username (mentor bot, leave empty to disable)
ALPHA_DOG_USERNAME=AlphaDog
